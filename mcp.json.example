{
  "_doc": [
    "Julie MCP server configuration.",
    "",
    "Julie runs as a stdio MCP server — your MCP client spawns it directly.",
    "Set JULIE_WORKSPACE to your project root (optional if cwd is the project)."
  ],

  "mcpServers": {
    "julie": {
      "command": "julie-server",
      "args": [],
      "env": {
        "JULIE_WORKSPACE": "/path/to/your/project"
      }
    }
  }
}
